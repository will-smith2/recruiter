      "properties": {
        "keywords": {
          "type": "string",
          "description": "搜索关键词，例如 '软件工程师', '产品经理'。"
        },
        "city": {
          "type": "string",
          "description": "目标工作城市，例如 '上海', '北京'。"
        },
        "source": {
          "type": "string",
          "description": "招聘网站来源，例如 'LinkedIn', 'Boss直聘'。"
        }
      },
      "required": ["keywords", "city"]
    }
  },
  {
